/* Popup Style */
.popup-container {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    padding: 30px;
    background-color: rgba(0, 0, 0, 0.6);
    z-index: 1000;
    display: flex; /* Always use flex, hide via JS if needed */
    justify-content: center;
    align-items: center;
    animation: slideInFromTop 0.6s ease-out;
    box-sizing: border-box;
}

/* Content wrapper */
.popup-content {
    border-radius: 10px;
    text-align: center;
    width: 100%;
    max-width: 537px;
    position: relative;
  padding: 10px;
    overflow: hidden;
}

/* Responsive Image */
.popup-image {
    width: 100%;
    height: 100%;
    border-radius: 10px;
    object-fit: cover;
    display: block;
}

/* Close icon styles */
.close-popup-icon {
    position: absolute;
    top: 10px;
    right: 12px;
    font-size: 32px;
    color: #afa183;
    cursor: pointer;
    font-weight: bold;
    z-index: 2;
}

.close-popup-icon:hover {
    color: #afa183;
}

/* Animation */
@keyframes slideInFromTop {
    0% {
        transform: translateY(-50px);
        opacity: 0;
    }
    100% {
        transform: translateY(0);
        opacity: 1;
    }
}

/* Mobile */
@media (max-width: 600px) {
    .popup-content {
        max-width: 95%;
   
    }

    .close-popup-icon {
        font-size: 28px;
        top: 6px;
        right: 10px;
    }
}


