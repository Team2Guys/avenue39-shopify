<script>
(function () {
  const WISHLIST_KEY = 'wishListsArr';

  // Get cleaned wishlist from localStorage
  function getWishlist() {
    const raw = localStorage.getItem(WISHLIST_KEY) || '[]';
    let list = [];
    try {
      list = JSON.parse(raw);
    } catch (e) {
      list = [];
    }
    return Array.isArray(list)
      ? list.filter(item => typeof item === 'string' && item.trim() !== '')
      : [];
  }

  // Save cleaned wishlist to localStorage
  function saveWishlist(list) {
    const cleanedList = list.filter(item => typeof item === 'string' && item.trim() !== '');
    localStorage.setItem(WISHLIST_KEY, JSON.stringify(cleanedList));
    updateWishlistCount();
  }

  // Update wishlist counter everywhere
  function updateWishlistCount() {
    const count = getWishlist().length;
    document.querySelectorAll('#WishlistCount, .WishlistCount, [data-wishlist-count]').forEach(el => {
      el.textContent = count;
    });
  }

  // Toggle wishlist (add/remove)
  window.toggleWishlist = function (element, productHandle) {
    if (!productHandle || typeof productHandle !== 'string' || productHandle.trim() === '') return;

    let wishlist = getWishlist();
    const index = wishlist.indexOf(productHandle);
    const icon = element.querySelector('i');
    const text = element.querySelector('.wishlist-text');

    if (index === -1) {
      wishlist.push(productHandle.trim());
      icon?.classList.remove('zmdi-favorite-outline');
      icon?.classList.add('zmdi-favorite');
      if (text) text.textContent = 'Added';

      document.dispatchEvent(new CustomEvent('wishlist:added', { detail: { productHandle } }));
    } else {
      wishlist.splice(index, 1);
      icon?.classList.remove('zmdi-favorite');
      icon?.classList.add('zmdi-favorite-outline');
      if (text) text.textContent = 'Add to Wishlist';

      document.dispatchEvent(new CustomEvent('wishlist:removed', { detail: { productHandle } }));
    }

    saveWishlist(wishlist);
  };

  // Remove item (used in trash icon or after Add to Cart)
  window.removeFromWishlist = function (element, productHandle) {
    if (!productHandle) return;
    let wishlist = getWishlist();
    wishlist = wishlist.filter(item => item !== productHandle);
    saveWishlist(wishlist);

    // Visually remove product container
    const productContainer = element.closest('.row') || element.closest('.wishlist-product');
    if (productContainer) {
      productContainer.style.transition = 'opacity 0.3s ease';
      productContainer.style.opacity = '0';
      setTimeout(() => productContainer.remove(), 300);
    }

    document.dispatchEvent(new CustomEvent('wishlist:removed', { detail: { productHandle } }));
  };

  // Add to cart and then remove from wishlist
  window.addToCartAndRemoveFromWishlist = function (element, productHandle, variantId = null) {
    const form = element.closest('form');
    if (form) {
      form.submit(); // fallback form submission
    }

    // Optional: AJAX cart logic goes here

    // Remove from wishlist
    removeFromWishlist(element, productHandle);
  };

  // Initialize on page load
  document.addEventListener('DOMContentLoaded', function () {
    updateWishlistCount();

    const wishlist = getWishlist();
    document.querySelectorAll('[data-product-handle]').forEach(btn => {
      const handle = btn.getAttribute('data-product-handle');
      const icon = btn.querySelector('i');
      const text = btn.querySelector('.wishlist-text');

      if (wishlist.includes(handle)) {
        icon?.classList.remove('zmdi-favorite-outline');
        icon?.classList.add('zmdi-favorite');
        if (text) text.textContent = 'Added';
      } else {
        icon?.classList.remove('zmdi-favorite');
        icon?.classList.add('zmdi-favorite-outline');
        if (text) text.textContent = 'Add to Wishlist';
      }
    });
  });
})();
</script>
