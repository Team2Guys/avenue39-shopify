<!-- Fixed Avenue39 Thank You Page Detection -->
<script>
// Avenue39 Thank You Page Detection - Fixed Version
(function() {
    console.log('Avenue39 tracking script loaded');
    
    function detectThankYouPage() {
        try {
            var url = window.location.href;
            console.log('Checking URL:', url);
            
            // Multiple detection methods for Avenue39
            var isThankYou = url.includes('thank-you') || 
                            url.includes('/checkouts/') ||
                            document.querySelector('.order-summary') ||
                            document.querySelector('[data-order-status]') ||
                            document.querySelector('.checkout-step-complete') ||
                            document.querySelector('.thank-you') ||
                            document.querySelector('.confirmation-number') ||
                            document.title.toLowerCase().includes('thank') ||
                            document.body.innerHTML.includes('Your order is confirmed') ||
                            document.body.innerHTML.includes('Confirmation #');

            console.log('Thank you page detected:', isThankYou);
            console.log('DataLayer available:', !!window.dataLayer);
            console.log('GTM available:', !!window.google_tag_manager);

            if (isThankYou) {
                console.log('✅ THANK YOU PAGE DETECTED!');
                console.log('URL:', url);
                console.log('Page Title:', document.title);
                
                // Check if dataLayer exists, if not create it
                if (!window.dataLayer) {
                    console.log('Creating dataLayer...');
                    window.dataLayer = [];
                }
                
                // Push to GTM dataLayer
                console.log('Pushing event to dataLayer...');
                window.dataLayer.push({
                    'event': 'custom_purchase_complete',
                    'page_type': 'thank-you',
                    'page_url': url,
                    'page_title': document.title,
                    'detection_method': getDetectionMethod(url),
                    'timestamp': new Date().getTime()
                });
                
                console.log('✅ GTM Event fired: custom_purchase_complete');
                console.log('Current dataLayer:', window.dataLayer);
                
                // Also trigger GA4 directly as backup (only if gtag is available)
                if (window.gtag) {
                    console.log('Firing GA4 direct event...');
                    gtag('event', 'purchase', {
                        transaction_id: 'avenue39_' + Date.now(),
                        value: 1.0,
                        currency: 'AED',
                        page_title: 'Avenue39 Thank You Page',
                        page_location: url,
                        custom_parameter_1: 'avenue39_thankyou'
                    });
                    console.log('✅ GA4 direct event fired');
                } else {
                    console.log('⚠️ gtag not available, skipping direct GA4 event');
                }
                
                return true; // Stop further attempts
            } else {
                console.log('❌ Not a thank you page');
                return false;
            }
            
        } catch (error) {
            console.error('Error in detectThankYouPage:', error);
            return false;
        }
    }
    
    function getDetectionMethod(url) {
        if (url.includes('thank-you')) return 'url_thank_you';
        if (url.includes('/checkouts/')) return 'url_checkout';
        if (document.querySelector('.order-summary')) return 'element_order_summary';
        if (document.querySelector('.confirmation-number')) return 'element_confirmation';
        if (document.title.toLowerCase().includes('thank')) return 'title_thank';
        return 'other';
    }
    
    // Function to run detection with multiple attempts
    function runDetectionWithRetry() {
        console.log('Running detection attempt...');
        var detected = detectThankYouPage();
        
        if (!detected) {
            console.log('Not detected, will retry...');
            // Try again after DOM elements load
            setTimeout(function() {
                console.log('Retry attempt 1...');
                detectThankYouPage();
            }, 2000);
            
            setTimeout(function() {
                console.log('Retry attempt 2...');
                detectThankYouPage();
            }, 4000);
            
            setTimeout(function() {
                console.log('Final retry attempt...');
                detectThankYouPage();
            }, 6000);
        }
    }
    
    // Run on page load
    console.log('Document ready state:', document.readyState);
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', function() {
            console.log('DOM Content Loaded');
            runDetectionWithRetry();
        });
    } else {
        console.log('Document already loaded');
        runDetectionWithRetry();
    }
    
    // Run on navigation changes (Shopify checkout uses navigation)
    var originalPushState = history.pushState;
    var originalReplaceState = history.replaceState;
    
    history.pushState = function() {
        originalPushState.apply(history, arguments);
        console.log('History push state detected');
        setTimeout(runDetectionWithRetry, 1000);
    };
    
    history.replaceState = function() {
        originalReplaceState.apply(history, arguments);
        console.log('History replace state detected');
        setTimeout(runDetectionWithRetry, 1000);
    };
    
    // Listen for URL changes
    window.addEventListener('popstate', function() {
        console.log('Pop state event detected');
        setTimeout(runDetectionWithRetry, 1000);
    });
    
    // Additional detection when window gains focus
    window.addEventListener('focus', function() {
        console.log('Window focus detected');
        setTimeout(detectThankYouPage, 500);
    });
    
    console.log('Avenue39 tracking script initialization complete');
})();
</script>

