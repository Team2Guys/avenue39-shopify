<style>
  .custom-slider-container {
    position: relative;
    overflow: hidden;
    width: 100%;
  }
  .custom-slider {
    display: flex;
    transition: transform 0.5s ease-in-out;
  }
  .custom-slide {
    flex: 0 0 calc(100% / {{ section.settings.slides_to_show }});
    text-align: center;
  }
  .custom-slide img {
    width: 100%;
    height: auto;
    object-fit: cover;
  }
  .custom-slider-controls {
    position: absolute;
    top: 50%;
    width: 100%;
    display: flex;
    justify-content: space-between;
    transform: translateY(-50%);
  }
  .custom-slider-arrow {
    background: rgba(0, 0, 0, 0.5);
    color: white;
    border: none;
    padding: 10px;
    cursor: pointer;
    font-size: 20px;
  }
  .custom-slider-dots {
    text-align: center;
    padding: 10px;
  }
  .custom-slider-dots button {
    background: #000;
    width: 10px;
    height: 10px;
    margin: 5px;
    border-radius: 50%;
    border: none;
    cursor: pointer;
  }
  .custom-slider-dots button.active {
    background: red;
  }
</style>

<div class="custom-slider-container">
  <div class="custom-slider">
    {% for block in section.blocks %}
      <div class="custom-slide">
        {% if block.settings.slide_image %}
          <a href="{{ block.settings.slide_link }}">
            <img src="{{ block.settings.slide_image | img_url: 'large' }}" alt="Slide">
          </a>
        {% else %}
          {{ block.settings.slide_text }}
        {% endif %}
      </div>
    {% endfor %}
  </div>

  {% if section.settings.arrows %}
    <div class="custom-slider-controls">
      <button class="custom-slider-arrow prev">&#10094;</button>
      <button class="custom-slider-arrow next">&#10095;</button>
    </div>
  {% endif %}

  {% if section.settings.dots %}
    <div class="custom-slider-dots"></div>
  {% endif %}
</div>

<script>
 document.addEventListener("DOMContentLoaded", function () {
  const slider = document.querySelector(".custom-slider");
  const slides = document.querySelectorAll(".custom-slide");
  const prevBtn = document.querySelector(".prev");
  const nextBtn = document.querySelector(".next");
  const dotsContainer = document.querySelector(".custom-slider-dots");
  
  let currentIndex = 0;
  const slideCount = slides.length;
  const slidesToShow = {{ section.settings.slides_to_show }};
  const autoplay = {{ section.settings.autoplay }};
  const autoplaySpeed = {{ section.settings.autoplay_speed }};
  let interval;

  // Clone first and last slides
  const firstClone = slides[0].cloneNode(true);
  const lastClone = slides[slideCount - 1].cloneNode(true);
  
  slider.appendChild(firstClone);
  slider.insertBefore(lastClone, slides[0]);

  const totalSlides = document.querySelectorAll(".custom-slide").length;
  const slideWidth = 100 / slidesToShow;

  slider.style.transform = `translateX(-${slideWidth}%)`;

  function updateSlider(transition = true) {
    if (transition) {
      slider.style.transition = "transform 0.5s ease-in-out";
    } else {
      slider.style.transition = "none";
    }
    slider.style.transform = `translateX(-${(currentIndex + 1) * slideWidth}%)`;
  }

  function goToNextSlide() {
    if (currentIndex >= slideCount - slidesToShow) {
      currentIndex++;
      updateSlider();
      setTimeout(() => {
        currentIndex = 0;
        updateSlider(false);
      }, 3000);
    } else {
      currentIndex++;
      updateSlider();
    }
    updateDots();
  }

  function goToPrevSlide() {
    if (currentIndex <= 0) {
      currentIndex--;
      updateSlider();
      setTimeout(() => {
        currentIndex = slideCount - slidesToShow;
        updateSlider(false);
      }, 3000);
    } else {
      currentIndex--;
      updateSlider();
    }
    updateDots();
  }

  function createDots() {
    for (let i = 0; i < slideCount; i++) {
      const dot = document.createElement("button");
      dot.classList.add("dot");
      if (i === currentIndex) dot.classList.add("active");
      dot.addEventListener("click", () => {
        currentIndex = i;
        updateSlider();
        updateDots();
      });
      dotsContainer.appendChild(dot);
    }
  }

  function updateDots() {
    const dots = document.querySelectorAll(".dot");
    dots.forEach((dot, index) => {
      dot.classList.toggle("active", index === currentIndex);
    });
  }

  if (nextBtn && prevBtn) {
    nextBtn.addEventListener("click", goToNextSlide);
    prevBtn.addEventListener("click", goToPrevSlide);
  }

  if (autoplay) {
    interval = setInterval(goToNextSlide, autoplaySpeed);
    slider.addEventListener("mouseenter", () => clearInterval(interval));
    slider.addEventListener("mouseleave", () => (interval = setInterval(goToNextSlide, autoplaySpeed)));
  }

  if (dotsContainer) {
    createDots();
  }
});
</script>

{% schema %}
{
  "name": "Custom Slider",
  "settings": [
    { "type": "range", "id": "slides_to_show", "label": "Slides to Show", "min": 1, "max": 6, "step": 1, "default": 3 },
    { "type": "checkbox", "id": "autoplay", "label": "Enable Autoplay", "default": true },
    { "type": "range", "id": "autoplay_speed", "label": "Autoplay Speed (ms)", "min": 500, "max": 5000, "step": 100, "default": 1000 },
    { "type": "checkbox", "id": "arrows", "label": "Show Arrows", "default": true },
    { "type": "checkbox", "id": "dots", "label": "Show Dots", "default": false }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        { "type": "text", "id": "slide_text", "label": "Slide Text", "default": "Slide Content" },
        { "type": "image_picker", "id": "slide_image", "label": "Slide Image" },
        { "type": "url", "id": "slide_link", "label": "Slide Link" }
      ]
    }
  ],
  "presets": [{ "name": "Custom Slider", "category": "Image", "blocks": [{ "type": "slide" }, { "type": "slide" }, { "type": "slide" }] }]
}
{% endschema %}
