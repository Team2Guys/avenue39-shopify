{% paginate blog.articles by section.settings.page_show_grid %}
<div class="blog-main-wrapper">
  
  <!-- Centralized Blog Title -->
  <div class="blog-header-title">
    <span class="category-label">BLOG</span>
  </div>

  <div class="blog-articles-list">
    {% for article in blog.articles %}
      <article class="article-item">
        
        <!-- 1. Title Above Image -->
        <h2 class="article-item__title">
          <a href="{{ article.url }}">{{ article.title }}</a>
        </h2>

        <!-- 2. Image with Date Badge Overlay -->
        <div class="article-item__image-container">
          <a href="{{ article.url }}" class="article-item__image-wrapper">
            <!-- Date Badge -->
            <div class="date-badge">
              <span class="day">{{ article.published_at | date: "%d" }}</span>
              <span class="month">{{ article.published_at | date: "%b" }}</span>
            </div>
            
            {% if article.image %}
               <img src="{{ article.image | img_url: '1200x' }}" 
                    alt="{{ article.image.alt | escape }}" 
                    class="article-item__image" 
                    loading="lazy" width="auto" height="auto">
            {% endif %}
          </a>
        </div>

        <!-- 3. Excerpt Content -->
        <div class="article-item__excerpt">
          {% if article.excerpt.size > 0 %}
            {{ article.excerpt | strip_html | truncate: 400 }}
          {% else %}
            {{ article.content | strip_html | truncate: 400 }}
          {% endif %}
        </div>

        <!-- 4. Styled Read More Button -->
        <div class="article-item__footer">
          <a href="{{ article.url }}" class="btn-continue-reading">
            CONTINUE READING 
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
          </a>
        </div>

        <hr class="article-separator">
      </article>
    {% endfor %}
  </div>

  {% if paginate.pages > 1 %}
    <div class="nov-pagination">
      {% include 'custom-pagination' %}
    </div>
  {% endif %}
</div>
{% endpaginate %}

<style>
  /* Global Layout matching your Next.js spacing */
  .blog-main-wrapper {
    max-width: 100%;
    margin: 0 auto;
  }

  .blog-header-title {
    text-align: center;
    margin-bottom: 20px;
  }

  .category-label {
    display: block;
    color: #c1a37f; /* Gold/Tan color from image */
    font-size: 14px;
    letter-spacing: 3px;
    margin-bottom: 10px;
    text-transform: uppercase;
  }

  .main-page-title {
    font-size: 32px;
    font-weight: 500;
    color: #000;
  }

  /* Article Card Styling */
  .article-item {
    margin-bottom: 20px;
  }

  .article-item__title {
    font-size: 40px;
    margin-bottom: 25px;
    text-align: center;
    font-weight: 600;
  }

  .article-item__title a {
    text-decoration: none;
    color: #000;
  }

  .article-item__image-container {
    position: relative;
    margin-bottom: 30px;
    overflow: hidden;
  }

  /* Date Badge Styling */
  .date-badge {
    position: absolute;
    top: 0;
    left: 0;
    background: #fff;
    padding: 10px 18px;
    z-index: 10;
    border: 1px solid #000;
    text-align: center;
    line-height: 1.2;
    min-width: 60px;
    font-size: 24px;
    font-weight: 600;
    color: #000;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .article-item__image {
    width: 100%;
    height: auto;
    display: block;
    transition: transform 0.5s ease;
  }

  .article-item__image-container:hover .article-item__image {
    transform: scale(1.03);
  }

  .article-item__excerpt {
    color: #000;
    line-height: 1.8;
    font-size: 16px;
    margin: 0 auto 30px;
    text-align: justify;
  }

  /* Button Styling */
  .btn-continue-reading {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background-color: #b5a48b; /* Desaturated tan from screenshot */
    color: #fff;
    padding: 12px 25px;
    text-decoration: none;
    font-size: 12px;
    letter-spacing: 1px;
    font-weight: 600;
    transition: background 0.3s;
  }

  .btn-continue-reading:hover {
    background-color: #9e8e75;
  }

  .article-separator {
    margin: 20px 0;
    border: 0;
    border-top: 1px solid #efefef;
  }

  /* Sidebar styling (to match Categories/Latest Posts list) */
  .sidebar-article h4 {
    font-size: 22px;
    margin-bottom: 20px;
    border-bottom: 2px solid #333;
    display: inline-block;
    padding-bottom: 5px;
  }

  @media (max-width: 767px) {
    .article-item__title { font-size: 20px; }
    .article-item__excerpt { font-size: 14px; }
  }
</style>