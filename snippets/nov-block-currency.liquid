{% if type == 'dropdown' %}
  <div class="currency-selector dropdown d-none d-md-flex align-items-center">
    {% if settings.title_currency != blank %}
      <div class="dropdown-label nv-mr-10">{{ settings.title_currency }}</div>
    {% endif %}
    <div
      class="dropdown-toggle"
      id="dropdownMenuButton"
      data-toggle="dropdown"
      aria-haspopup="true"
      aria-expanded="false"
    >
      <span class="current-currency"></span><span class="caret"></span>
    </div>
    <div id="_desktop_currency_selector" class="dropdown-menu" aria-labelledby="dropdownMenuButton">
      {% assign currency = settings.supported_currencies | split: '|' %}
      <div id="currencies">
        {% for value in currency %}
          {% assign currency_item = value | split: ',' %}
          {% assign Dhs = currency_item[0] | upcase | strip %}
          {% assign symbol = currency_item[1] | strip %}
          <li class="currency__item list-inline-item">
            {% if Dhs == 'AED' %}
              <span data-currency="{{ Dhs }}">Dhs</span>
            {% else %}
              <span data-currency="{{ Dhs }}">{{ symbol }}</span>
            {% endif %}
          </li>
        {% endfor %}
      </div>
    </div>
  </div>
{% else %}
  <div id="_desktop_currency_selector" class="currency-selector groups-selector">
    {% assign currency = settings.supported_currencies | split: '|' %}
    <ul id="currencies" class="list-inline nv-pl-25">
      {% for value in currency %}
        {% assign currency_item = value | split: ',' %}
        {% assign Dhs = currency_item[0] | upcase | strip %}
        {% assign symbol = currency_item[1] | strip %}
        <li class="currency__item list-inline-item">
          {% if Dhs == 'AED' %}
            <span data-currency="{{ Dhs }}">Dhs</span>
          {% else %}
            <span data-currency="{{ Dhs }}">{{ symbol }}</span>
          {% endif %}
        </li>
      {% endfor %}
    </ul>
  </div>
{% endif %}
